{
  "name": "@resonatehq/aws",
  "version": "0.1.4",
  "description": "Resonate FaaS handler for AWS Lambda Functions (TypeScript)",
  "repository": {
    "url": "https://github.com/resonatehq/resonate-faas-aws-ts"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "resonate",
    "faas",
    "aws",
    "aws-lambda",
