    "@types/bun": "latest",
    "open": "^10.2.0",
    "@types/aws-lambda": "^8.10.156"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@resonatehq/sdk": "^0.10.0"
